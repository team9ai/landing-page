NEXT_PUBLIC_LANDING_BASE_URL=https://team9.ai
NEXT_PUBLIC_APP_BASE_URL=https://app.team9.ai
# Cloudflare R2 public domain (large assets that overflow the Pages 25 MB limit)
NEXT_PUBLIC_ASSET_CDN_URL=https://cdn.team9.ai

# Google Identity Services client id, must match VITE_GOOGLE_CLIENT_ID in the
# team9 client repo so an ID token minted on the homepage is accepted by the
# server's POST /api/v1/auth/google endpoint.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Analytics & Tag Manager
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_APP_VERSION=0.1.0